AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_LOG_LEVEL=INFO

PARSER_ENABLE_OCR=false
PARSER_TEMP_DIR=/tmp/knowledge-ai
PARSER_MAX_OCR_PAGES=50
PARSER_MAX_VLM_IMAGES=20
OCR_FAIL_MODE=partial_success
VLM_FAIL_MODE=partial_success

# Provider switches. mock = no external dependency.
OCR_PROVIDER=mock
EMBEDDING_PROVIDER=mock
RERANK_PROVIDER=mock
LLM_PROVIDER=mock
VLM_PROVIDER=mock

# VLM knobs.
VLM_MODEL_NAME=qwen-vl-max
# AI_VLM_ENDPOINT falls back to AI_LLM_ENDPOINT if not set. For Qwen use: https://dashscope.aliyuncs.com/compatible-mode/v1
AI_VLM_ENDPOINT=

# Embedding model knobs.
EMBEDDING_MODEL_NAME=mock-embedding-v1
EMBEDDING_DIMENSION=16
AI_EMBEDDING_ENDPOINT=http://localhost:8001

# LLM knobs. LLM_PROVIDER: mock | openai-compatible | qwen | private-http.
LLM_MODEL_NAME=mock-llm
AI_LLM_ENDPOINT=http://localhost:8001
LLM_API_KEY=
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=2048

# Rerank knobs.
RERANK_MODEL_NAME=mock-rerank
RERANK_API_KEY=
# RERANK_PROVIDER=private-http expects this to be the full rerank endpoint.
AI_RERANK_ENDPOINT=http://localhost:8001/api/v1/rerank

# Shared HTTP client knobs.
AI_REQUEST_TIMEOUT=60
AI_MAX_CONCURRENCY=8

# Provider API keys (leave empty for mock).
OPENAI_API_KEY=
QWEN_API_KEY=
EMBEDDING_API_KEY=
