# Local development ports
BACKEND_PORT=8080
AI_SERVICE_PORT=8001
WEB_PORT=5173

POSTGRES_PORT=5432
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OPENSEARCH_PORT=9200
OPENSEARCH_PERFORMANCE_PORT=9600
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091

# Image overrides. Keep defaults unless your network needs a trusted internal mirror.
POSTGRES_IMAGE=postgres:16
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:latest
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.19.3
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.18
MILVUS_MINIO_IMAGE=minio/minio:latest
MILVUS_IMAGE=milvusdb/milvus:v2.6.6

# Metadata database: PostgreSQL is the default MVP database.
POSTGRES_DB=knowledge
POSTGRES_USER=knowledge_app
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_URL=jdbc:postgresql://localhost:5432/knowledge

# Optional MySQL profile.
MYSQL_DATABASE=knowledge
MYSQL_USER=knowledge_app
MYSQL_PASSWORD=change-me-local-mysql
MYSQL_ROOT_PASSWORD=change-me-local-mysql-root
MYSQL_URL=jdbc:mysql://localhost:3306/knowledge

# Redis
REDIS_HOST=localhost

# MinIO local object storage. Replace these before using shared environments.
MINIO_ROOT_USER=knowledge_minio
MINIO_ROOT_PASSWORD=change-me-local-minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=knowledge-documents

# Optional OpenSearch profile.
# SEARCH_ENGINE: database = JPA like keyword search, opensearch = OpenSearch REST client.
SEARCH_ENGINE=database
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-me-OpenSearch-Admin-123!
SEARCH_INDEX_PREFIX=knowledge
SEARCH_REQUEST_TIMEOUT=10s

# Optional Milvus profile.
# VECTOR_STORE_ENGINE: mock = in-database mock vector search, milvus = Milvus REST client.
VECTOR_STORE_ENGINE=mock
MILVUS_ENDPOINT=http://localhost:19530
MILVUS_TOKEN=root:Milvus
MILVUS_MINIO_ACCESS_KEY=milvus_minio
MILVUS_MINIO_SECRET_KEY=change-me-local-milvus-minio
VECTOR_COLLECTION_PREFIX=knowledge
VECTOR_STORE_REQUEST_TIMEOUT=10s
VECTOR_STORE_FAIL_FAST=false

# App integration
AI_SERVICE_ENDPOINT=http://localhost:8001
AI_SERVICE_PARSE_PATH=/api/parse/document
AI_SERVICE_EMBEDDING_PATH=/api/v1/embeddings
AI_SERVICE_EMBEDDING_MODEL=mock-embedding-v1
AI_SERVICE_TIMEOUT=60s
PARSE_TASK_EXECUTOR_AUTO_RUN=false
PARSE_TASK_EXECUTOR_FIXED_DELAY=10s
PARSE_TASK_WORKER_ID=backend-local
EMBEDDING_TASK_EXECUTOR_AUTO_RUN=false
EMBEDDING_TASK_EXECUTOR_FIXED_DELAY=10s
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CONSUMER_GROUP=knowledge-backend-group
KNOWLEDGE_KAFKA_ENABLED=true
KNOWLEDGE_STORAGE_TYPE=local
KNOWLEDGE_STORAGE_LOCAL_ROOT=data/uploads
KNOWLEDGE_CHUNK_SIZE=800
KNOWLEDGE_CHUNK_OVERLAP=100

# Backend Security & Snowflake ID Config
KNOWLEDGE_SECURITY_ENABLED=false
OAUTH2_JWT_ISSUER_URI=
OAUTH2_JWT_JWK_SET_URI=
KNOWLEDGE_WORKER_ID=1
KNOWLEDGE_DATACENTER_ID=1

# LLM provider config (backend + ai-service share these names).
# LLM_PROVIDER: mock | openai-compatible | qwen | private-http. mock is the MVP default.
LLM_PROVIDER=mock
LLM_MODEL_NAME=mock-llm
LLM_API_KEY=
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=2048

# Embedding / rerank provider config (used by ai-service, surfaced for backend alignment).
BACKEND_EMBEDDING_PROVIDER=mock
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL_NAME=mock-embedding-v1
EMBEDDING_DIMENSION=16
EMBEDDING_API_KEY=
RERANK_PROVIDER=mock
RERANK_MODEL_NAME=mock-rerank
RERANK_API_KEY=

# AI service model endpoints / runtime knobs.
AI_SERVICE_INSTALL_OCR=false
PARSER_ENABLE_OCR=false
OCR_PROVIDER=mock
VLM_PROVIDER=mock
VLM_MODEL_NAME=qwen-vl-max
AI_VLM_ENDPOINT=
AI_LLM_ENDPOINT=http://localhost:8001
AI_LLM_TIMEOUT=60
AI_EMBEDDING_ENDPOINT=http://localhost:8001
# RERANK_PROVIDER=private-http expects a full rerank endpoint.
AI_RERANK_ENDPOINT=http://localhost:8001/api/v1/rerank
AI_REQUEST_TIMEOUT=60
AI_MAX_CONCURRENCY=8
