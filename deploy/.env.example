# Local development ports
BACKEND_PORT=8080
AI_SERVICE_PORT=8001
WEB_PORT=5173

POSTGRES_PORT=5432
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OPENSEARCH_PORT=9200
OPENSEARCH_PERFORMANCE_PORT=9600
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091

# Image overrides. Keep defaults unless your network needs a trusted internal mirror.
POSTGRES_IMAGE=postgres:16
MYSQL_IMAGE=mysql:8.4
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:latest
OPENSEARCH_IMAGE=opensearchproject/opensearch:2.19.3
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.18
MILVUS_MINIO_IMAGE=minio/minio:latest
MILVUS_IMAGE=milvusdb/milvus:v2.6.6

# Metadata database: PostgreSQL is the default MVP database.
POSTGRES_DB=knowledge
POSTGRES_USER=knowledge_app
POSTGRES_PASSWORD=change-me-local-postgres
POSTGRES_URL=jdbc:postgresql://localhost:5432/knowledge

# Optional MySQL profile.
MYSQL_DATABASE=knowledge
MYSQL_USER=knowledge_app
MYSQL_PASSWORD=change-me-local-mysql
MYSQL_ROOT_PASSWORD=change-me-local-mysql-root
MYSQL_URL=jdbc:mysql://localhost:3306/knowledge

# Redis
REDIS_HOST=localhost

# MinIO local object storage. Replace these before using shared environments.
MINIO_ROOT_USER=knowledge_minio
MINIO_ROOT_PASSWORD=change-me-local-minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=knowledge-documents

# Optional OpenSearch profile.
SEARCH_ENGINE=mock
OPENSEARCH_ENDPOINT=http://localhost:9200
OPENSEARCH_INITIAL_ADMIN_PASSWORD=change-me-OpenSearch-Admin-123!
SEARCH_INDEX_PREFIX=knowledge

# Optional Milvus profile.
VECTOR_STORE_ENGINE=mock
MILVUS_ENDPOINT=http://localhost:19530
MILVUS_MINIO_ACCESS_KEY=milvus_minio
MILVUS_MINIO_SECRET_KEY=change-me-local-milvus-minio
VECTOR_COLLECTION_PREFIX=knowledge

# App integration
AI_SERVICE_ENDPOINT=http://localhost:8001
KNOWLEDGE_STORAGE_TYPE=local
KNOWLEDGE_STORAGE_LOCAL_ROOT=data/uploads
KNOWLEDGE_CHUNK_SIZE=800
KNOWLEDGE_CHUNK_OVERLAP=100
